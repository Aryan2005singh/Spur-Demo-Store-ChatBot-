// Prisma Schema — Spur Demo Store Support Chat
// Docs: https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon requires connection pooling in serverless environments.
  // If using Neon's pooled connection URL, set directUrl separately:
  // directUrl = env("DIRECT_URL")
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// A conversation session. Created when a user sends their first message.
/// Acts as the top-level container for all messages in a session.
model Conversation {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]

  @@map("conversations")
}

/// A single message within a conversation.
/// sender: "user" | "assistant" — matches LLM role naming.
model Message {
  id             String       @id @default(uuid())
  conversationId String
  sender         String       // "user" | "assistant"
  text           String       @db.Text
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])  // Optimises history queries
  @@map("messages")
}
